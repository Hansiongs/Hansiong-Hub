local TradeConfig = getgenv().TradeConfig
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local HttpService = game:GetService("HttpService")
local UserInputService = game:GetService("UserInputService")
local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- 1. DATA INITIALIZATION
local DataReplion = require(ReplicatedStorage.Packages.Replion).Client:WaitReplion("Data")
local TileInteractionController = require(ReplicatedStorage.Controllers.InventoryController.TileInteraction)

-- 2. VARIABLES & DATABASE
local ItemDatabase, DBFish, DBRod, DBEnchant, EnchantMap = {}, nil, nil, nil, {}
local TierToRarity = {[1]="COMMON", [2]="UNCOMMON", [3]="RARE", [4]="EPIC", [5]="LEGENDARY", [6]="MYTHIC", [7]="SECRET"}

pcall(function()
    DBFish = HttpService:JSONDecode(game:HttpGet('https://raw.githubusercontent.com/Hansiongs/Hansiong-Hub/refs/heads/main/fishlists'))
    DBRod = HttpService:JSONDecode(game:HttpGet('https://raw.githubusercontent.com/Hansiongs/Hansiong-Hub/refs/heads/main/rodlists'))
    DBEnchant = HttpService:JSONDecode(game:HttpGet('https://raw.githubusercontent.com/Hansiongs/Hansiong-Hub/refs/heads/main/enchantlists'))
    for _, v in pairs(DBEnchant) do EnchantMap[tostring(v.Id)] = v.EnchantName end
end)

local function LoadDB(folder)
    if not folder then return end
    for _, v in ipairs(folder:GetChildren()) do
        local ok, data = pcall(require, v)
        if ok and (data.Data or data) then
            local info = data.Data or data
            local id, name = tostring(info.Id or v.Name), tostring(info.Name or v.Name)
            if DBFish and DBFish[id] then 
                info.Tier, info.Rarity = DBFish[id].Tier, DBFish[id].Rarity or info.Rarity 
            end
            local rarity = info.Rarity and string.upper(tostring(info.Rarity)) or TierToRarity[info.Tier] or "COMMON"
            ItemDatabase[id] = { Name = name, Rarity = rarity, Tier = info.Tier }
            ItemDatabase[name] = ItemDatabase[id]
        end
    end
end

LoadDB(ReplicatedStorage:FindFirstChild("Items"))
if ReplicatedStorage:FindFirstChild("Database") then
    LoadDB(ReplicatedStorage.Database:FindFirstChild("Fish"))
    LoadDB(ReplicatedStorage.Database:FindFirstChild("Items"))
end

local function GetItemInfo(id_or_name)
    return ItemDatabase[tostring(id_or_name)] or { Name = tostring(id_or_name), Rarity = "UNKNOWN", Tier = 0 }
end

-- 3. DISCORD WEBHOOK HELPER
local function SendWebhook(title, description, color, fields)
    if not TradeConfig.DiscordWebhook or TradeConfig.DiscordWebhook == "" or TradeConfig.DiscordWebhook == "ISI_LINK_WEBHOOK_DISCORD_LU_DISINI" then return end
    local req = (http_request or request or (syn and syn.request) or (fluxus and fluxus.request))
    if not req then return end
    
    local data = {
        ["embeds"] = {{
            ["title"] = title,
            ["description"] = description,
            ["color"] = color,
            ["fields"] = fields
        }}
    }
    
    pcall(function()
        req({
            Url = TradeConfig.DiscordWebhook,
            Method = "POST",
            Headers = {["Content-Type"] = "application/json"},
            Body = HttpService:JSONEncode(data)
        })
    end)
end

-- 4. GUI BYPASS & INTERACTION HELPERS
local function ForceClick(guiObject)
    if not guiObject or not getconnections then return end
    pcall(function()
        for _, conn in ipairs(getconnections(guiObject["InputBegan"]) or {}) do
            if type(conn.Function) == "function" then
                task.spawn(conn.Function, {
                    UserInputState = Enum.UserInputState.Begin, 
                    UserInputType = Enum.UserInputType.Touch,
                    Position = Vector3.new(guiObject.AbsolutePosition.X + (guiObject.AbsoluteSize.X / 2), guiObject.AbsolutePosition.Y + (guiObject.AbsoluteSize.Y / 2), 0),
                    GetPropertyChangedSignal = function(self) 
                        return { 
                            Connect = function(_, cb) 
                                task.delay(0.1, function() self.UserInputState = Enum.UserInputState.End; cb() end)
                                return {Disconnect=function()end} 
                            end 
                        } 
                    end
                })
            end
        end
    end)
end

local function EquipItemFromInv(itemData, itemName)
    local display = PlayerGui:FindFirstChild("Backpack") and PlayerGui.Backpack:FindFirstChild("Display")
    if not display then return false end

    local cleanName = string.gsub(string.lower(itemName), "[%s\n]", "")
    
    local function FindTile()
        for _, child in ipairs(display:GetChildren()) do
            for _, desc in ipairs(child:GetDescendants()) do
                if desc:IsA("TextLabel") and string.find(string.gsub(string.lower(desc.Text), "[%s\n]", ""), cleanName) then 
                    return child 
                end
            end
        end
        return nil
    end

    local function WaitForTile(timeout)
        local timeWaited = 0
        while timeWaited < timeout do
            local found = FindTile()
            if found then return found end
            timeWaited = timeWaited + task.wait(0.1)
        end
        return nil
    end

    local targetTile = FindTile()
    if not targetTile then 
        pcall(function() TileInteractionController:HandleInventoryClick(itemData, {Data={Type="Fish"}}, false, nil) end)
        targetTile = WaitForTile(2) 
    end
    if not targetTile then 
        pcall(function() TileInteractionController:HandleInventoryClick(itemData, {Data={Type="Fish"}}, false, nil) end)
        targetTile = WaitForTile(2) 
    end
    if not targetTile then return false end

    pcall(function()
        for _, evt in ipairs({"Activated", "MouseButton1Click", "TouchTap"}) do
            for _, conn in ipairs(getconnections and getconnections(targetTile[evt]) or {}) do conn:Fire() end
        end
        if firesignal then firesignal(targetTile.Activated) end
        if fireclick then fireclick(targetTile) end
    end)
    task.wait(0.2)
    
    pcall(function() 
        for _, conn in ipairs(getconnections and getconnections(UserInputService.TouchTapInWorld) or {}) do 
            conn:Fire(Vector2.new(0, 0), false) 
        end 
    end)
    return true
end

local function WaitAndClickPrompt(timeoutSeconds)
    local promptUI = PlayerGui:WaitForChild("Prompt", 3)
    if not promptUI then return false end
    
    local waitTime = 0
    while not promptUI.Enabled and waitTime < timeoutSeconds do
        waitTime = waitTime + task.wait(0.1)
    end
    
    if promptUI.Enabled then
        local yesBtn = promptUI:FindFirstChild("Yes", true)
        if not yesBtn then
            for _, desc in ipairs(promptUI:GetDescendants()) do
                if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and (desc.Text == "Yes" or desc.Text == "Confirm") then 
                    yesBtn = desc.Parent:IsA("GuiButton") and desc.Parent or desc 
                    break 
                end
            end
        end
        if yesBtn then
            ForceClick(yesBtn)
            return true
        end
    end
    return false
end

-- 5. ITEM SCANNER LOGIC
local function GetMatchingItems()
    local inventory = {}
    for _, v in ipairs(DataReplion:Get({"Inventory", "Items"}) or {}) do table.insert(inventory, v) end
    for _, v in ipairs(DataReplion:Get({"Inventory", "Fish"}) or {}) do table.insert(inventory, v) end

    local matchedItems = {}
    for _, item in ipairs(inventory) do
        if not (TradeConfig.UnfavoritedOnly and item.Favorited) then
            local info = GetItemInfo(item.Id)
            local variant = item.Metadata and item.Metadata.VariantId 
            
            local isTierMatch = false
            if TradeConfig.EnableTradeTiers then
                isTierMatch = (info.Tier == TradeConfig.TradeTiers) or (info.Rarity == "SECRET")
            end
            
            local isWhitelistMatch = false
            if TradeConfig.EnableWhitelist then
                isWhitelistMatch = (TradeConfig.WhitelistId[item.Id] and variant and TradeConfig.WhitelistVariant[variant])
            end
            
            if isTierMatch or isWhitelistMatch then
                table.insert(matchedItems, {
                    Data = item,
                    InfoName = info.Name,
                    FinalName = variant and (variant .. " " .. info.Name) or info.Name,
                    UUID = item.UUID
                })
            end
        end
    end
    return matchedItems
end

-- 6. TRADE SENDER & VALIDATOR
local function StartAutoTrade()
    -- CARI PLAYER
    local targetPlayer = Players:FindFirstChild(TradeConfig.TargetUsername)
    if not targetPlayer then
        for _, v in ipairs(Players:GetPlayers()) do 
            if v.DisplayName == TradeConfig.TargetUsername then targetPlayer = v break end 
        end
    end
    if not targetPlayer then return warn("[AutoTrade] Target '" .. TradeConfig.TargetUsername .. "' tidak ditemukan.") end

    -- PRE-SCAN (Cek Ketersediaan Item)
    local targetItems = GetMatchingItems()
    if #targetItems == 0 then
        warn("[AutoTrade] Item yang diinginkan trade gaada di inventory.")
        SendWebhook(
            "⚠️ Trade Dibatalkan",
            "Item yang sesuai konfigurasi (Tier/Whitelist) **TIDAK ADA** di inventory.",
            16711680, 
            {
                {name = "👤 Pengirim", value = LocalPlayer.Name, inline = true},
                {name = "🎯 Target", value = TradeConfig.TargetUsername, inline = true}
            }
        )
        if writefile then
        pcall(function() 
            if isfolder and not isfolder("Workspace") and makefolder then
                makefolder("Workspace")
            end
            writefile("trade_done.txt", "selesai") 
        end)
        return
    end

    -- PROSES TRADE
    local maxTrade = type(TradeConfig.Amount) == "number" and TradeConfig.Amount or math.huge
    local tradeCount = 0
    local attemptedTrades = {} 
    
    for _, itemObj in ipairs(targetItems) do
        if tradeCount >= maxTrade then break end
        
        local success, attempts = false, 0
        while not success and attempts < 3 do
            attempts = attempts + 1
            
            if not EquipItemFromInv(itemObj.Data, itemObj.InfoName) then
                warn("[AutoTrade] Gagal equip " .. itemObj.FinalName)
            else
                local pRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                local tRoot = targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart")
                if pRoot and tRoot then 
                    pRoot.CFrame = tRoot.CFrame * CFrame.new(0, 0, 0) + Vector3.new(0, 1, 0)
                    pRoot.CFrame = CFrame.lookAt(pRoot.Position, tRoot.Position)
                end
                task.wait(0.5) 
                
                local prompt = tRoot and tRoot:FindFirstChildWhichIsA("ProximityPrompt")
                if prompt and prompt.ActionText == "Give" and fireproximityprompt then
                    fireproximityprompt(prompt)
                    
                    if WaitAndClickPrompt(10) then
                        task.wait(2.5) -- Jeda cepat antara Pop-Up 1 dan 2
                        
                        if WaitAndClickPrompt(15) then
                            success = true
                            tradeCount = tradeCount + 1
                            attemptedTrades[itemObj.UUID] = itemObj.FinalName
                            print("[AutoTrade] Berhasil mengeksekusi trade: " .. itemObj.FinalName)
                            task.wait(TradeConfig.TradeDelay)
                        else
                            warn("[AutoTrade] Prompt konfirmasi KEDUA tidak muncul/gagal.")
                        end
                    else
                        warn("[AutoTrade] Prompt konfirmasi PERTAMA tidak muncul/gagal.")
                    end
                end
            end
            
            -- JIKA GAGAL, LAKUKAN CLEANUP GUI YANG NYANGKUT
            if not success then
                warn("[AutoTrade] Percobaan " .. attempts .. " gagal. Membersihkan GUI tersangkut untuk " .. itemObj.FinalName)
                local promptUI = PlayerGui:FindFirstChild("Prompt")
                if promptUI and promptUI.Enabled then
                    local noBtn = promptUI:FindFirstChild("No", true)
                    if not noBtn then
                        for _, desc in ipairs(promptUI:GetDescendants()) do
                            if (desc:IsA("TextLabel") or desc:IsA("TextButton")) and (desc.Text == "No" or desc.Text == "Cancel") then 
                                noBtn = desc.Parent:IsA("GuiButton") and desc.Parent or desc 
                                break 
                            end
                        end
                    end
                    if noBtn then
                        ForceClick(noBtn)
                        task.wait(0.5)
                    else
                        promptUI.Enabled = false -- Fallback paksa tutup
                    end
                end
                task.wait(1.5) -- Jeda nafas sebelum mencoba ulang
            end
        end
        
        if not success then
            warn("[AutoTrade] SKIP ITEM: " .. itemObj.FinalName .. " | Gagal setelah 3 kali percobaan.")
        end
    end

    -- POST-SCAN (Make Sure Validation & Hitung Sisa)
    print("[AutoTrade] Memverifikasi data ke server...")
    task.wait(4) -- Beri waktu server menghapus item dari tas
    
    local itemsAfterTrade = GetMatchingItems()
    local remainingUUIDs = {}
    local remainingItemsCount = {}
    local totalRemaining = 0
    
    -- Kumpulin data item sisa
    for _, itemObj in ipairs(itemsAfterTrade) do
        remainingUUIDs[itemObj.UUID] = true
        remainingItemsCount[itemObj.FinalName] = (remainingItemsCount[itemObj.FinalName] or 0) + 1
        totalRemaining = totalRemaining + 1
    end

    local successfulItemsCount = {}
    local realTotalTrade = 0
    
    -- Cek mana UUID yang beneran HILANG dari tas
    for uuid, finalName in pairs(attemptedTrades) do
        if not remainingUUIDs[uuid] then
            realTotalTrade = realTotalTrade + 1
            successfulItemsCount[finalName] = (successfulItemsCount[finalName] or 0) + 1
        else
            warn("[Make Sure] Gagal pindah tangan: " .. finalName .. " (Item ternyata masih nangkring di tas)")
        end
    end

    -- FORMAT LIST TRADE (Yang Berhasil)
    local listTradeString = ""
    for itemName, count in pairs(successfulItemsCount) do
        listTradeString = listTradeString .. "• " .. itemName .. " (x" .. count .. ")\n"
    end
    if listTradeString == "" then listTradeString = "*Tidak ada item yang berhasil ditrade*" end

    -- FORMAT LIST SISA INVENTORY (Yang Masih Sesuai Kriteria)
    local listRemainingString = ""
    for itemName, count in pairs(remainingItemsCount) do
        listRemainingString = listRemainingString .. "• " .. itemName .. " (x" .. count .. ")\n"
    end
    if listRemainingString == "" then listRemainingString = "*Tidak ada sisa item (Habis bersih)*" end

    -- KIRIM WEBHOOK HASIL AKHIR
    SendWebhook(
        "✅ Auto-Trade Selesai",
        "Laporan pengiriman item ke target.",
        65280, -- Warna Hijau
        {
            {name = "👤 Pengirim", value = LocalPlayer.Name, inline = true},
            {name = "🎯 Target", value = TradeConfig.TargetUsername, inline = true},
            {name = "📦 Total Berhasil", value = tostring(realTotalTrade), inline = true},
            {name = "📋 List Trade Berhasil", value = listTradeString, inline = false},
            {name = "🎒 Sisa Inventory (" .. tostring(totalRemaining) .. ")", value = listRemainingString, inline = false}
        }
    )

    if writefile then
        pcall(function() 
            if isfolder and not isfolder("Workspace") and makefolder then
                makefolder("Workspace")
            end
            writefile("trade_done.txt", "selesai") 
        end)
    end
end 

-- 7. START
task.spawn(function()
    StartAutoTrade()
end)
